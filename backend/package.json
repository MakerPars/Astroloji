{
  "name": "astrology-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:doppler": "npm run doppler:devvars && wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:doppler": "npm run doppler:cf-secrets && wrangler deploy",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "doppler:devvars": "tsx scripts/render-dev-vars.ts",
    "doppler:cf-secrets": "tsx scripts/sync-cloudflare-secrets.ts",
    "seed": "tsx scripts/seed-content.ts",
    "schema:apply": "tsx scripts/generate-schema.ts"
  },
  "dependencies": {
    "hono": "^4.8.3",
    "jose": "^6.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260301.0",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "wrangler": "^4.37.1"
  }
}
